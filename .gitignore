.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.local

# ── Editor / OS ──────────────────────────────────────────────────────────────
.DS_Store
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# ── Logs ─────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Vercel ───────────────────────────────────────────────────────────────────
.vercel/

# ── Coverage ─────────────────────────────────────────────────────────────────
coverage/
*.lcov

# ── Misc ─────────────────────────────────────────────────────────────────────
*.local
*.log
.cache/
tmp/
