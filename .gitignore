# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ── Build output ─────────────────────────────────────────────────────────────
dist/
build/
.next/
out/
*.tsbuildinfo

# ── Environment & secrets ────────────────────────────────────────────────────
